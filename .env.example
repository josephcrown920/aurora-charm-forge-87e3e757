# =============================================================================
# Aurora Studio — Example environment file
# =============================================================================
# Copy to `.env.local` ONLY for local experimentation. In Lovable Cloud the
# real `.env` is auto-generated (Supabase publishable values only) and every
# runtime secret lives in Project Settings → Secrets (process.env at runtime).
#
# DO NOT put real secret values in this file. DO NOT commit a populated `.env`.
# See docs/KLING_SECRETS.md and docs/ENV.md for the full policy.
# =============================================================================

# -------- Public (safe to expose, RLS-enforced) --------------------------------
VITE_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="eyJhbGciOi...PUBLISHABLE_ANON_KEY..."
VITE_SUPABASE_PROJECT_ID="your-project-ref"
SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
SUPABASE_PUBLISHABLE_KEY="eyJhbGciOi...PUBLISHABLE_ANON_KEY..."

# -------- Supabase (server only, NEVER ship to client) -------------------------
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOi...SERVICE_ROLE..."     # JWT, ~250 chars
SUPABASE_DB_URL="postgresql://postgres:PASSWORD@db.YOUR-REF.supabase.co:5432/postgres"

# -------- AI fallback chain ----------------------------------------------------
LOVABLE_API_KEY="lov_sk_..."                                  # managed; rotate via tool
GEMINI_API_KEY="AIza..."                                      # 39 chars, starts AIza
OPENAI_API_KEY="sk-..."                                       # starts sk-
OPENROUTER_API_KEY="sk-or-v1-..."                             # starts sk-or-
INFERENCE_API_KEY="inf_..."

# -------- Media / video --------------------------------------------------------
FAL_KEY="00000000-0000-0000-0000-000000000000:0123456789abcdef"   # UUID:hex
SYNC_API_KEY="sk_sync_..."

# -------- Kling AI (direct, used by *.server.ts only) --------------------------
# Get both from https://app.klingai.com/global/dev/document-api
# Format: alphanumeric strings, ~24–40 chars each. NEVER commit real values.
KLING_ACCESS_KEY="AKxxxxxxxxxxxxxxxxxxxxxx"                   # Access Key ID
KLING_SECRET_KEY="SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"        # Secret Key (JWT signer)

# -------- Payments / infra -----------------------------------------------------
PAYSTACK_SECRET_KEY="sk_test_..."                             # sk_test_ or sk_live_
CRON_SECRET="generate-a-long-random-string"                   # >=32 chars
