# Aurora Studio Environment Variables
# Copy this to .env.local and fill in your values
# See QUICK_START.md for setup instructions

# ============================================================
# REQUIRED - Core Services
# ============================================================

# Lovable API (Main generation provider)
LOVABLE_API_KEY=your_lovable_key_here

# Supabase (Database)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ============================================================
# OPTIONAL - Image Generation Providers
# ============================================================

# Gemini (Free tier, fallback priority 1)
GEMINI_API_KEY=your_gemini_key_here

# Replicate (Paid, fallback priority 3)
REPLICATE_API_KEY=your_replicate_key_here

# HuggingFace (Free tier, fallback priority 2)
HF_TOKEN=your_huggingface_token_here

# ============================================================
# OPTIONAL - Video Generation Providers
# ============================================================

# Kling (JWT-signed, cheaper than Replicate)
KLING_ACCESS_KEY=your_kling_access_key_here
KLING_SECRET_KEY=your_kling_secret_key_here

# ============================================================
# OPTIONAL - Avatar & Lipsync Providers
# ============================================================

# HeyGen (Avatar-based video & lipsync)
HEYGEN_API_KEY=your_heygen_key_here

# Sync.so (Lipsync preferred provider)
SYNC_API_KEY=your_sync_api_key_here

# ============================================================
# OPTIONAL - Catch-All Fallback
# ============================================================

# Fal.ai (Ultimate fallback for any generation type)
FAL_KEY=your_fal_key_here

# ============================================================
# OPTIONAL - Text & Other Services
# ============================================================

# OpenRouter (LLM inference gateway, optional)
OPENROUTER_API_KEY=your_openrouter_key_here

# OpenAI (Alternative LLM, optional)
OPENAI_API_KEY=your_openai_key_here

# ============================================================
# OPTIONAL - Monetization & Payments
# ============================================================

# Paystack (Payment processing)
PAYSTACK_PUBLIC_KEY=your_paystack_public_key_here
PAYSTACK_SECRET_KEY=your_paystack_secret_key_here

# Stripe (Alternative payment, future)
STRIPE_PUBLIC_KEY=your_stripe_public_key_here
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# ============================================================
# OPTIONAL - Email Services
# ============================================================

# Resend (Current email provider)
RESEND_API_KEY=your_resend_key_here

# Mailgun (Alternative email, future)
MAILGUN_API_KEY=your_mailgun_key_here
MAILGUN_DOMAIN=your_mailgun_domain_here

# SendGrid (Alternative email, future)
SENDGRID_API_KEY=your_sendgrid_key_here

# ============================================================
# OPTIONAL - Monitoring & Analytics
# ============================================================

# Sentry (Error tracking)
SENTRY_DSN=your_sentry_dsn_here

# PostHog (Analytics)
POSTHOG_API_KEY=your_posthog_key_here
POSTHOG_PROJECT_ID=your_posthog_project_id_here

# ============================================================
# OPTIONAL - Development
# ============================================================

# Enable debug logging
DEBUG=false
LOG_LEVEL=info

# Node environment
NODE_ENV=development

# ============================================================
# NOTES
# ============================================================

# 1. Only LOVABLE_API_KEY + Supabase are REQUIRED
# 2. Other providers are optional (app has fallbacks)
# 3. For development, only set what you need
# 4. For production, set all keys if available
# 5. Never commit .env.local to git
# 6. Use .env.local for local development
# 7. Use platform environment for deployed apps
# 8. See QUICK_START.md for setup instructions
